#!/usr/bin/env bash
set -u

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/ARGOS_RUNTIME/tools/tag_from_argos_version.ps1"

if [ ! -f "$SCRIPT" ]; then
  exit 0
fi

if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT" -RepoRoot "$REPO_ROOT" || true
elif command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "$SCRIPT" -RepoRoot "$REPO_ROOT" || true
fi
