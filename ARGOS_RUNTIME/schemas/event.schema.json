{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event Schema",
  "type": "object",
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "actor": { "type": "string" },
    "module": { "type": "string" },
    "type": { "type": "string" },
    "summary": { "type": "string" },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "verification": { "type": "string" },
    "next_step": { "type": "string" },
    "errors": { "type": "string" },
    "risks": { "type": "string" }
  },
  "required": [
    "timestamp", "actor", "module", "type", "summary", "errors", "risks"
  ]
}
