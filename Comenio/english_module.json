{
  "name": "English Module (Comenio, narrative-first, dict+log)",
  "version": "4.2.0",
  "updated_at": "2025-12-13T20:30:00Z",

  "identity_ref": "comenio_identity.json",
  "use_identity": {
    "voice": true,
    "ethos": true,
    "classroom_values": true,
    "style_guides": true
  },

  "banks": {
    "syllabus": "syllabus.v1.2.json",
    "class_structure_library": "class_structure_library.json",
    "profiler_template": "profiler_template.json"
  },

  "runtime_policies": {
    "token_budget_hint": 1200,
    "max_plan_minutes": 60,

    "memory": {
      "persist": [
        "student_profile_summary",
        "progress_summary",
        "last_log_entry",
        "last_class_recap",
        "recent_modality_ids",
        "recent_grammar_ids",
        "recent_skill_ids"
      ],
      "forget": [
        "verbatim_long_texts",
        "raw_audio_transcripts_over_1k_chars"
      ]
    },

    "interaction": {
      "prefer_interactions": ["individual", "plenary", "small_group"],
      "avoid_interactions": ["pairwork"]
    },

    "language_switch": {
      "ui_language": "es",
      "target_language": "en",
      "rule": "A1–A2 explicaciones meta en ES; ≥B1 en EN salvo que el usuario pida ES."
    }
  },

  "log_update_behavior": {
    "default_mode": "deferred_compilation",
    "note": [
      "No se recalcula todo el historial en cada turno.",
      "Si el usuario pide 'siguiente clase': (1) recap anterior (solo la anterior), (2) nueva clase, (3) propuesta de log-entry para copiar/pegar.",
      "Si el usuario pide 'recopila todo': entonces sí, reconstruir logs/signals leyendo conversación/documentos."
    ]
  },

  "dict_and_log_support": {
    "profile_paths": {
      "dict": "profile.dict",
      "log_entries": "profile.log.entries",
      "signals": "profile.signals"
    },

    "log_entry_format": {
      "fields": {
        "n": "class_number",
        "d": "date_YYMMDD_int",
        "m": "modality_id_int",
        "s": "session_type_id_int",
        "g": "grammar_id_int_array",
        "k": "skill_ids_int_array",
        "e": "error_codes_array",
        "f": "needs_review_flag_0_1"
      },
      "token_budget": {
        "target_tokens_per_entry": "35–60",
        "hard_limit_tokens_per_entry": "90",
        "rules": {
          "g_max": 2,
          "k_max": 3,
          "e_max": 4
        }
      }
    },

    "dict_rules": {
      "G": "syllabus grammar_ids (canonical) id->grammar_id",
      "K": "skills/teaching_actions id->label",
      "M": "modalities id->class_structure_id",
      "S": "session_types id->label",
      "E": "error_codes code->description",

      "id_assignment": {
        "numeric_ids_start_at": 1,
        "new_id_policy": "smallest_unused_positive_int"
      }
    }
  },

  "library_index_usage": {
    "enabled": true,
    "note": [
      "Si class_structure_library incluye 'indexes', se usan para seleccionar modalidades/activities/materials rápidamente.",
      "Si no existe 'indexes', se hace fallback a escanear arrays (modalities/assets)."
    ],
    "paths": {
      "modalities_by_id": "indexes.lookup.modalities_by_id",
      "activities_by_id": "indexes.lookup.activities_by_id",
      "materials_by_id": "indexes.lookup.materials_by_id",

      "activities_by_grammar_id": "indexes.activities.by_grammar_id",
      "activities_by_level": "indexes.activities.by_level",
      "activities_by_skill": "indexes.activities.by_skill",
      "activities_by_best_stage": "indexes.activities.by_best_stage",
      "activities_by_interaction": "indexes.activities.by_interaction",

      "materials_by_grammar_id": "indexes.materials.by_grammar_id",
      "materials_by_level_hint": "indexes.materials.by_level_hint",
      "materials_by_type": "indexes.materials.by_type"
    },
    "fallback_scan": {
      "modalities": true,
      "activities": true,
      "materials": true
    }
  },

  "tag_canonicalization": {
    "canonical_id_prefix": "grammar_paths.",
    "aliases_to_grammar_id": {
      "present_simple": "grammar_paths.verb_tenses_and_voice.present_simple",
      "there_is_are": "grammar_paths.verb_tenses_and_voice.there_is_are",
      "present_continuous": "grammar_paths.verb_tenses_and_voice.present_continuous",
      "past_simple": "grammar_paths.verb_tenses_and_voice.past_simple",
      "past_continuous": "grammar_paths.verb_tenses_and_voice.past_continuous",
      "be_going_to": "grammar_paths.verb_tenses_and_voice.be_going_to",
      "future_simple": "grammar_paths.verb_tenses_and_voice.future_simple",
      "present_perfect_simple": "grammar_paths.verb_tenses_and_voice.present_perfect_simple",
      "present_perfect_continuous": "grammar_paths.verb_tenses_and_voice.present_perfect_continuous",

      "questions": "grammar_paths.questions",
      "clauses": "grammar_paths.clauses",

      "adverbs": "grammar_paths.adverbs",
      "pronouns": "grammar_paths.pronouns",
      "determiners": "grammar_paths.determiners",
      "articles": "grammar_paths.determiners.articles",
      "prepositions": "grammar_paths.prepositions",

      "comparatives": "grammar_paths.adjectives.comparatives",
      "superlatives": "grammar_paths.adjectives.superlatives",

      "reported_speech": "grammar_paths.reported_speech",
      "modality": "grammar_paths.modality",

      "frequency_adverbs": "grammar_paths.adverbs",
      "question_forms": "grammar_paths.questions",
      "present_continuous_future": "grammar_paths.verb_tenses_and_voice.present_continuous"
    },

    "unknown_tag_handling": {
      "action": "capture_to_library_inbox",
      "capture_fields": ["raw_tag", "context", "suggested_grammar_id_if_any"]
    },

    "output_policy": {
      "max_grammar_ids_to_show": 2,
      "show_only_canonical": true
    }
  },

  "syllabus_ref_resolver": {
    "canonical_id_prefix": "grammar_paths.",
    "levels_container": {
      "path": "levels",
      "type_priority": ["array_of_objects", "map"],
      "array_level_key": "level"
    },
    "path_aliases": {
      "verb_tenses": "verb_tenses_and_voice"
    },
    "ref_shorthand_rules": [
      "If ref matches '<LEVEL>.<PATH>': resolve inside that level’s grammar_paths.<PATH>.",
      "If <PATH> points to an object: expand to all leaf subpaths (category expansion).",
      "If <PATH> points to an array: the canonical id is 'grammar_paths.<PATH>' (terminal container)."
    ],
    "output_ids_are": "grammar_paths.<category>[.<subcategory>...]"
  },

  "linguistic_regulator": {
    "note": [
      "Handler previo: filtra y prioriza rutas del syllabus con precisión A1.1…C1.2.",
      "El syllabus sigue siendo la fuente canónica; aquí solo definimos qué partes del syllabus son 'activas' por micro-banda.",
      "En output se muestran como mucho 1–2 grammar_ids canónicos."
    ],

    "micro_band_resolution": {
      "inheritance": {
        "rule": "band .2 hereda .1; A2 hereda A1; etc.",
        "how": "aplicar extends en cadena y luego merge de arrays (sin duplicados)"
      },
      "syllabus_ref_shorthand": {
        "format": "<LEVEL>.<CATEGORY>[.<SUBCATEGORY>.]",
        "examples": ["A1.adjectives", "A1.clauses.declarative", "B1.reported_speech"]
      }
    },

    "micro_bands": {
      "A1.1": {
        "syllabus_level": "A1",
        "max_output_ids": 2,
        "include_refs": [
          "A1.adjectives",
          "A1.pronouns",
          "A1.determiners",
          "A1.prepositions",
          "A1.questions",
          "A1.clauses.declarative",
          "A1.clauses.interrogatives",
          "A1.clauses.coordinated",
          "A1.verb_tenses_and_voice.present_simple",
          "A1.verb_tenses_and_voice.there_is_are"
        ]
      },

      "A1.2": {
        "extends": "A1.1",
        "delta": {
          "add_include_refs": [
            "A1.adverbs",
            "A1.conjunctions",
            "A1.clauses.subordinated",
            "A1.verb_tenses_and_voice.past_simple"
          ]
        }
      },

      "A2.1": {
        "syllabus_level": "A2",
        "max_output_ids": 2,
        "include_refs": [
          "A2.questions",
          "A2.adverbs",
          "A2.determiners",
          "A2.clauses.conditional",
          "A2.adjectives.comparatives",
          "A2.verb_tenses_and_voice.past_simple",
          "A2.verb_tenses_and_voice.past_continuous",
          "A2.verb_tenses_and_voice.be_going_to"
        ]
      },

      "A2.2": {
        "extends": "A2.1",
        "delta": {
          "add_include_refs": [
            "A2.adjectives.superlatives",
            "A2.reported_speech",
            "A2.clauses.relative",
            "A2.verb_tenses_and_voice.present_perfect_simple"
          ]
        }
      },

      "B1.1": {
        "syllabus_level": "B1",
        "max_output_ids": 2,
        "include_refs": [
          "B1.modality",
          "B1.questions",
          "B1.reported_speech",
          "B1.clauses.relative",
          "B1.verb_tenses_and_voice.present_perfect_simple",
          "B1.verb_tenses_and_voice.present_perfect_continuous",
          "B1.verb_tenses_and_voice.past_perfect_simple"
        ]
      },

      "B1.2": {
        "extends": "B1.1",
        "delta": {
          "add_include_refs": [
            "B1.prepositions",
            "B1.clauses.conditional",
            "B1.verb_tenses_and_voice.passive_voice",
            "B1.verb_tenses_and_voice.past_perfect_continuous"
          ]
        }
      },

      "B2.1": {
        "syllabus_level": "B2",
        "max_output_ids": 2,
        "include_refs": [
          "B2.modality",
          "B2.reported_speech",
          "B2.clauses",
          "B2.questions",
          "B2.verb_tenses_and_voice.passive_voice",
          "B2.verb_tenses_and_voice.future_continuous",
          "B2.verb_tenses_and_voice.future_perfect_simple"
        ]
      },

      "B2.2": {
        "extends": "B2.1",
        "delta": {
          "add_include_refs": [
            "B2.discourse_markers",
            "B2.focus",
            "B2.verb_tenses_and_voice.present_perfect_continuous"
          ]
        }
      },

      "C1.1": {
        "syllabus_level": "C1",
        "max_output_ids": 2,
        "include_refs": [
          "C1.modality",
          "C1.clauses",
          "C1.discourse_markers",
          "C1.focus"
        ]
      },

      "C1.2": {
        "extends": "C1.1",
        "delta": {
          "add_include_refs": [
            "C1.reported_speech",
            "C1.prepositions"
          ]
        }
      }
    }
  },

  "asset_retrieval": {
    "use_library_indexes_if_present": true,

    "activity_query_order": [
      "by_grammar_id",
      "by_level",
      "by_best_stage",
      "by_skill",
      "by_interaction"
    ],

    "material_query_order": [
      "by_grammar_id",
      "by_level_hint",
      "by_type"
    ],

    "max_candidates": {
      "activities": 12,
      "materials": 8
    },

    "fallback_scan_if_no_index_hit": true
  },

  "selection_policy": {
    "primary_selector": "class_structure_library.modalities",
    "mode": "soft",
    "threshold": 1.5,
    "weights": {
      "level_fit": 1.2,
      "skill_fit": 1.0,
      "novelty": 0.8,
      "signal_priority": 1.1,
      "interaction_fit": 0.6
    },
    "cooldowns": {
      "avoid_last_k_sessions_same_modality": 2
    }
  },

  "session_type_analyzer": {
    "enabled": true,
    "dict_key": "S",
    "log_field": "s",

    "features_used": [
      "m (modality)",
      "g (syllabus grammar ids)",
      "k (skills/actions)",
      "stage_signature (e.g. repetition_rounds=3, story_branching=true, error_workshop=true)",
      "product_type (spoken_performance|written_microtext|debate|roleplay)"
    ],

    "label_builder": {
      "pattern": "{modality_core}_{main_grammar_leaf}_{skill_emphasis}",
      "examples": [
        "narrative_arc_questions_speaking",
        "accuracy_workshop_present_perfect_error_correction"
      ]
    },

    "id_rules": {
      "create_if_missing": true,
      "new_id_policy": "smallest_unused_positive_int"
    },

    "library_capture": {
      "when_activity_not_matched": "push_to_class_structure_library.assets.inbox.uncategorized_activities",
      "when_material_not_matched": "push_to_class_structure_library.assets.inbox.uncategorized_materials"
    }
  },

  "pipeline": [
    "Apply identity (tone, style, language).",
    "Detect mode: if quick_explain → answer_short → end.",
    "Load student profile (if any) + objectives; infer level, micro_band, constraints.",
    "If request is 'next class': produce previous_class_recap (previous-only) using profile.log.entries[-1] or previous plan.",
    "Normalize labels (warmer → warmup).",
    "Resolve micro_band (A1.1…C1.2): apply inheritance; compute active syllabus refs (include_refs).",
    "From objectives + signals.review_queue, pick ≤2 canonical grammar IDs inside the active refs.",
    "Select modality using class_structure_library (indexes if present; else scan).",
    "Assemble class plan from modality stages; generate narrative/content; retrieve activities/materials via indexes when possible.",
    "If a new activity/material emerges and is not categorized → capture to class_structure_library.assets.inbox.",
    "Run session_type_analyzer → resolve/create session_type_id (dict.S) and include it in the proposed log entry.",
    "Emit a compact log-entry proposal (n,d,m,s,g,k,e,f) for teacher copy/paste."
  ],

  "output_spec": {
    "format": "teacher_outline_default",
    "strict": true,
    "include_previous_class_recap_when_applicable": true,
    "include_log_entry_proposal": true
  },

  "capabilities": [
    "lesson_design",
    "pedagogical_advice",
    "content_transformation",
    "reflection_support",
    "dialogue_mediation",
    "dict_log_encoding_support"
  ]
}
