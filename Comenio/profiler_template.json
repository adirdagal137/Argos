      "recent_window_policy": {
        "window_size_classes": 30,
        "auto_flag_thresholds": {
          "error_seen_times_in_window": 8,
          "grammar_seen_times_in_window": 10
        }
      }
    },

    "teacher_notes": {
      "what_has_worked_before": [],
      "what_to_avoid_because_it_fails": [],
      "motivation_triggers": []
    }
  },

  "update_policy": {
    "after_next_class_request": [
      "append log.entries",
      "increment signals.grammar_hits for each g ID",
      "increment signals.error_hits for each e code",
      "update review_queue if thresholds met"
    ],
    "review_triggers": ["teacher_request", "every_5_sessions", "clear_level_change_evidence"],
    "what_to_update_first": [
      "progress.next_small_wins",
      "constraints.allowed_for_output.grammar_ids",
      "diagnostics.typical_errors",
      "signals.review_queue"
    ]
  }
