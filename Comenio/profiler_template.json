    "dict": {
      "note": [
        "Diccionarios para comprimir el historial por clase.",
        "Claves de objeto son strings por JSON; los IDs se usan como números en los logs.",
        "G guarda grammar_ids canónicos del syllabus como strings 'grammar_paths...'."
      ],

      "G": {
        "note": "Grammar IDs canónicos del syllabus: id (int) -> grammar_id (string 'grammar_paths...')",
        "1": "grammar_paths.verb_tenses_and_voice.present_simple",
        "2": "grammar_paths.questions"
      },

      "K": {
        "note": "Skills/acciones pedagógicas: id (int) -> etiqueta corta",
