    },

    "goals": {
      "primary": "",
      "secondary": "",
      "time_horizon_weeks": null,
      "success_criteria": []
    },

    "constraints": {
      "max_sentence_length": null,

      "allowed_for_output": {
        "grammar_ids": [],
        "functions": [],
        "notes": ""
      },

      "allowed_for_input": {
        "grammar_ids": [],
        "functions": [],
        "notes": ""
      },

      "avoid_for_now": {
        "grammar_ids": [],
